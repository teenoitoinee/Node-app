# MongoDB Connection String
# สำหรับ Railway: Railway จะ set เอง ผ่าน Environment Variables
# สำหรับ Local: ใช้ MongoDB Atlas หรือ Local MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gps-tracker?retryWrites=true&w=majority

# Server Port
PORT=3000

# Node Environment
NODE_ENV=production